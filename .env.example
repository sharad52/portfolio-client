# ─────────────────────────────────────────────────────────────
#  Contact handling (no backend required)
#  Configure ONE of the two below. Without either, the contact
#  form falls back to WhatsApp automatically.
# ─────────────────────────────────────────────────────────────

# OPTION A (recommended, free, Google) — Google Apps Script web app URL.
# Submissions are saved to a Google Sheet you own AND emailed to you.
# Setup guide: docs/contact-google-sheet.md
VITE_GOOGLE_SCRIPT_URL=

# OPTION B — Web3Forms access key (free key at https://web3forms.com).
# Submissions are emailed to you.
VITE_WEB3FORMS_KEY=

# WhatsApp number in international format, DIGITS ONLY (country code + number).
# Defaults to the value in src/content/site.ts if left blank.
VITE_WHATSAPP_NUMBER=9779847895491

# App metadata (optional)
VITE_APP_NAME=Sharad Bhandari — Portfolio
